# ===========================
# Noor Islamic App — Environment Variables
# ===========================
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# --- Database (PostgreSQL) ---
# Required for the API server (user accounts, calendar events, adhkar progress)
# Example: postgresql://user:password@host:5432/noor_db
DATABASE_URL=postgresql://user:password@localhost:5432/noor_db

# --- JWT Auth ---
# Secret used to sign user tokens. Use a long random string in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# --- Server Port (API only) ---
PORT=8080

# --- Frontend Base Path (Vite) ---
# Leave as "/" for standard deployments (Vercel, Netlify, GitHub Pages at root)
BASE_PATH=/

# --- Frontend API URL ---
# Where the frontend sends API requests.
# On Vercel: set this to your backend API URL (Railway, Render, etc.)
# In development: leave empty — the vite proxy or local server handles it.
VITE_API_URL=
