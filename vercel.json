{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @workspace/noor run build",
  "outputDirectory": "artifacts/noor/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
